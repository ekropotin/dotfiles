{
    "layer": "top",
    "spacing": 0,
    "height": 0,

    "margin-top": 0,
    "margin-right": 0,
    "margin-bottom": 0,
    "margin-left": 0,

    "modules-left": [
        "sway/workspaces",
        "sway/mode"
    ],

    "modules-center": [
        "clock"
    ],

    "modules-right": [
        "tray",
        "custom/mouse-battery",
        "battery",
        "cpu",
        "memory"
    ],

    "sway/mode": {
        "tooltip": false
    },

    "sway/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "tooltip": false
    },

    "tray": {
        "spacing": 10,
        "tooltip": false
    },

    "clock": {
        "format": "{:%a %d, %I:%M %p}",
        "tooltip": false
    },

    "custom/mouse-battery": {
        "exec": "~/.config/waybar/scripts/mouse_battery.sh",
        "interval": 60,
        "tooltip": false
    },

    "battery": {
        "format": "bat {capacity}%",
        "format-charging": "bat+ {capacity}%",
        "format-full": "bat full",
        "interval": 30,
        "states": {
            "warning": 30,
            "critical": 15
        },
        "tooltip": false
    },

    "cpu": {
        "format": "cpu {usage}%",
        "interval": 2,

        "states": {
            "critical": 90
        }
    },

    "memory": {
        "format": "mem {percentage}%",
        "interval": 2,

        "states": {
            "critical": 80
        }
    }
}
