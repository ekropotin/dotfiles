[core]
    pager = delta

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true
    side-by-side = false
    line-numbers = true
    hyperlinks = true
    dark = true
    syntax-theme = "Catppuccin Mocha"
    hunk-header-style = file line-number syntax
    hunk-header-decoration-style = none

[merge]
    conflictstyle = zdiff3
